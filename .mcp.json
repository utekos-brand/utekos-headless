{
  "mcpServers": {
    "vercel": {
      "type": "http",
      "url": "https://mcp.vercel.com"
    },
    "utekos-frost": {
      "url": "http://localhost:3060/api/mcp/frost",
      "headers": {
        "x-utekos-agent": "marketer"
      }
    },
    "wcag": {
      "command": "npx",
      "args": [
        "-y",
        "wcag-guidelines-mcp"
      ]
    },
    "tailwindcss-server": {
      "command": "npx",
      "args": [
        "-y",
        "tailwindcss-mcp-server"
      ]
    },
    "shadcn": {
      "command": "npx",
      "args": [
        "shadcn@latest",
        "mcp"
      ]
  },
  "chrome-devtools": {
    "command": "npx",
    "args": [
      "-y",
      "chrome-devtools-mcp@latest"
    ]
  },
  "google-tag-manager-mcp-server": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote",
        "https://gtm-mcp.stape.ai/mcp"
      ]
    },
  "mdn": {
    "url": "https://mcp.mdn.mozilla.net/"
  },
  "next-devtools": {
    "command": "npx",
    "args": [
      "-y",
      "next-devtools-mcp@latest"
    ]
  },
  "playwright": {
    "command": "npx",
    "args": [
      "@playwright/mcp@latest"
    ]
  },
  "ga4-mcp-server": {
     "command": "npx",
      "args": [
        "-y",
        "mcp-remote",
        "https://mcp-google-analytics.stape.io/mcp"
      ]
    },
"facebook-ads": {
      "url": "https://mcp.facebook.com/ads",
      "headers": {
        "ACCESS_TOKEN": "${input:facebookAdsToken}",
        "META_PIXEL_ID": "${input:metaPixelId}",
        "SYSTEM_USER_TOKEN": "${input:systemUserToken}"
      }
    }
},
  "inputs": [
    { "id": "facebookAdsToken", "type": "promptString", "description": "Facebook Ads bearer token", "password": true },
    { "id": "metaPixelId", "type": "promptString", "description": "Meta Pixel ID" },
    { "id": "systemUserToken", "type": "promptString", "description": "Meta System User token", "password": true }
  ]
}