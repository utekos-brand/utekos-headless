# Ignore local/generated GitHub-adjacent payloads by default.
*
!.gitignore

# GitHub-managed dependency/security automation.
!dependabot.yml
!dependabot.yaml

# GitHub Actions workflows must remain trackable.
!workflows/
workflows/*
!workflows/*.yml
!workflows/*.yaml

# GitHub review, security, and community metadata.
!CODEOWNERS
!PULL_REQUEST_TEMPLATE.md
!PULL_REQUEST_TEMPLATE/
PULL_REQUEST_TEMPLATE/*
!PULL_REQUEST_TEMPLATE/*.md
!ISSUE_TEMPLATE/
ISSUE_TEMPLATE/*
!ISSUE_TEMPLATE/*.md
!ISSUE_TEMPLATE/*.yml
!ISSUE_TEMPLATE/*.yaml
!SECURITY.md
!SUPPORT.md
!FUNDING.yml

# Keep generated/local agent material ignored.
skills/
skills/**
modernize/
modernize/**
