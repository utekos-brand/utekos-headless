{
  "envFiles": {
    "primary": ".env.mcp.local",
    "fallback": ".env.local"
  },
  "credentialFiles": {
    "GA_SERVICE_ACCOUNT_JSON": {
      "path": "src/api/lib/cloud-credentials/google-analytics-data-api-service-account.json",
      "servers": ["google-analytics"],
      "required": false
    },
    "GOOGLE_APPLICATION_CREDENTIALS": {
      "path": "src/api/lib/cloud-credentials/search-console-credentials.json",
      "servers": ["gsc"],
      "required": false
    },
    "MERCHANT_CENTER_CREDENTIALS_PATH": {
      "path": "src/api/lib/cloud-credentials/merchant-center-credentials.json",
      "servers": ["merchant-data-mcp"],
      "required": false
    }
  },
  "requiredEnv": {
    "CONTEXT7_API_KEY": {
      "servers": ["context7", "upstash-context7"],
      "description": "Context7 MCP API key (ctx7sk-...)"
    }
  },
  "optionalEnv": {
    "FIRECRAWL_API_KEY": { "servers": ["firecrawl-mcp"] },
    "TRENDS_MCP_BEARER_TOKEN": { "servers": ["trends-mcp"] },
    "CLARITY_API_TOKEN": { "servers": ["@microsoft/clarity-mcp-server"] },
    "GOOGLE_DEVELOPER_KNOWLEDGE_API_KEY": { "servers": ["google-developer-knowledge"] },
