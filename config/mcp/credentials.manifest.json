    "META_APP_ID": { "servers": ["meta-ads", "meta-ads-read-only"] },
    "META_AUTO_REFRESH": { "servers": ["meta-ads", "meta-ads-read-only"] },
    "META_BUSINESS_ID": { "servers": ["meta-ads", "meta-ads-read-only"] },
    "META_AD_ACCOUNT_ID": { "servers": ["utekos-commerce-tracking"] },
    "META_PIXEL_ID": { "servers": ["utekos-commerce-tracking"] },
    "MICROSOFT_ADS_DEVELOPER_TOKEN": { "servers": ["utekos-commerce-tracking"] },
    "MICROSOFT_ADS_CLIENT_ID": { "servers": ["utekos-commerce-tracking"] },
    "MICROSOFT_ADS_CLIENT_SECRET": { "servers": ["utekos-commerce-tracking"] },
    "MICROSOFT_ADS_ACCESS_TOKEN": { "servers": ["utekos-commerce-tracking"] },
    "MICROSOFT_ADS_REFRESH_TOKEN": { "servers": ["utekos-commerce-tracking"] },
    "MICROSOFT_ADS_CUSTOMER_ID": { "servers": ["utekos-commerce-tracking"] },
    "MICROSOFT_ADS_ACCOUNT_ID": { "servers": ["utekos-commerce-tracking"] },
    "MICROSOFT_ADS_ENVIRONMENT": { "servers": ["utekos-commerce-tracking"] },
