    "PAGESPEED_GOOGLE_API_KEY": { "servers": ["pagespeed"] },
    "GA_PROPERTY_ID": { "servers": ["google-analytics"] },
    "GA_MEASUREMENT_ID": { "servers": ["google-analytics"] },
    "GA_API_SECRET": { "servers": ["google-analytics"] },
    "GOOGLE_PROJECT_ID": { "servers": ["google-ads-mcp"] },
    "GOOGLE_ADS_DEVELOPER_TOKEN": { "servers": ["google-ads-mcp", "utekos-commerce-tracking"] },
    "GOOGLE_ADS_CUSTOMER_ID": { "servers": ["google-ads-mcp", "utekos-commerce-tracking"] },
    "GOOGLE_ADS_LOGIN_CUSTOMER_ID": { "servers": ["google-ads-mcp"] },
    "GOOGLE_ADS_MANAGER_ID": { "servers": ["google-ads-mcp"] },
    "GOOGLE_ADS_CLIENT_ID": { "servers": ["google-ads-mcp"] },
    "GOOGLE_ADS_CLIENT_SECRET": { "servers": ["google-ads-mcp"] },
