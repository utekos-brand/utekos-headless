{
  "mcpServers": {
    "openai": {
      "type": "http",
      "url": "https://developers.openai.com/mcp",
      "tools": [
        "fetch_openai_doc",
        "get_openapi_spec",
        "list_api_endpoints",
        "list_openai_docs",
        "search_openai_docs"
      ]
    },
    "coolors": {
      "type": "local",
      "command": "npx",
      "args": [
        "-y",
        "@trishchuk/coolors-mcp"
      ],
      "tools": [
        "adjust_color",
        "analyze_color_likability",
        "analyze_palette_consistency",
        "check_contrast",
        "check_palette_accessibility",
        "color_distance",
        "convert_color",
        "export_palette",
        "extract_image_colors",
        "fix_disliked_colors_batch",
        "generate_gradient",
        "generate_material_theme",
        "generate_palette",
        "generate_palette_with_locks",
        "generate_semantic_palette",
        "generate_state_colors",
        "generate_theme_css",
        "generate_theme_from_image",
        "generate_tonal_palette",
        "generate_tonal_scale",
        "harmonize_colors",
        "match_theme_color",
        "match_theme_colors_batch",
        "refactor_css_with_theme",
        "simulate_color_blindness"
      ]
    },
    "shopify-dev-mcp": {
      "type": "local",
      "command": "npx",
      "args": [
        "-y",
        "@shopify/dev-mcp@latest"
      ],
      "tools": [
        "learn_shopify_api",
        "search_docs_chunks",
        "validate_component_codeblocks",
        "validate_graphql_codeblocks",
        "validate_theme"
      ]
    },
    "wcag": {
      "type": "local",
      "command": "npx",
      "args": [
        "-y",
        "wcag-guidelines-mcp"
      ],
      "tools": [
        "count-criteria",
        "get-criteria-by-level",
        "get-criterion",
        "get-failures-for-criterion",
        "get-full-criterion-context",
        "get-glossary-term",
        "get-guideline",
        "get-server-info",
        "get-success-criteria-detail",
        "get-technique",
        "get-techniques-for-criterion",
        "list-glossary-terms",
        "list-guidelines",
        "list-principles",
        "list-success-criteria",
        "list-techniques",
        "search-glossary",
        "search-techniques",
        "search-wcag",
        "whats-new-in-wcag22"
      ]
    },
    "context7": {
      "type": "http",
      "url": "https://mcp.context7.com/mcp",
      "tools": [
        "query-docs",
        "resolve-library-id"
      ]
    },
    "mdn": {
      "type": "http",
      "url": "https://mcp.mdn.mozilla.net/",
      "tools": [
        "get-compat",
        "get-doc",
        "search"
      ]
    }
  }
}
