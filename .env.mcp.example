# MCP tooling secrets for utekos-headless
# Copy to .env.mcp.local and fill in values, then run: npm run mcp:build
#
# App runtime secrets stay in .env.local (vercel env pull).
# Never commit real API keys, access tokens, refresh tokens, developer tokens,
# customer IDs, account IDs, service-account emails, or GTM workspace IDs here.

# --- Required for Context7 ---
CONTEXT7_API_KEY=

# --- API keys ---
FIRECRAWL_API_KEY=
TRENDS_MCP_BEARER_TOKEN=
CLARITY_API_TOKEN=
GOOGLE_DEVELOPER_KNOWLEDGE_API_KEY=
PAGESPEED_GOOGLE_API_KEY=

# --- Dedicated ChatGPT Shopify read-only app ---
# Use Dev Dashboard client credentials for this app only. Do not reuse the
# broad SHOPIFY_ADMIN_API_TOKEN. Requested scopes: read_orders,
# read_all_orders, read_customers (protected customer data applies).
SHOPIFY_CHATGPT_STORE_DOMAIN=
SHOPIFY_CHATGPT_CLIENT_ID=
SHOPIFY_CHATGPT_CLIENT_SECRET=
SHOPIFY_CHATGPT_API_VERSION=2026-04

# --- Google Cloud / Analytics ---
GOOGLE_CLOUD_QUOTA_PROJECT=
GOOGLE_ANALYTICS_APPLICATION_CREDENTIALS=src/api/lib/cloud-credentials/tag-manager-credentials.json
GA_PROPERTY_ID=
GA_MEASUREMENT_ID=

# --- Google Ads MCP ---
GOOGLE_PROJECT_ID=
GOOGLE_ADS_APPLICATION_CREDENTIALS=.agent-artifacts/google-ads-adc/application_default_credentials.json
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
GOOGLE_ADS_MANAGER_ID=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_ACCESS_TOKEN=
GOOGLE_ADS_OAUTH_ACCESS_TOKEN=
GOOGLE_ADS_SERVICE_ACCOUNT_JSON=
GOOGLE_ADS_API_VERSION=

# --- Google Merchant Center MCP ---
# Canonical Merchant API keys used by app runtime and commerce MCP probes.
GOOGLE_MERCHANT_ACCOUNT_ID=
GOOGLE_MERCHANT_QUOTA_PROJECT=
GOOGLE_MERCHANT_DATA_SOURCE_ID=
GOOGLE_MERCHANT_SERVICE_ACCOUNT_JSON=
# Legacy/local aliases kept for external MCP tools where applicable.
MERCHANT_CENTER_ID=
MERCHANT_CENTER_API_DEVELOPER=
MERCHANT_CENTER_SERVICE_ACCOUNT=

# --- GTM MCP ---
GTM_CLIENT_ID=
GTM_CLIENT_SECRET=
GTM_PROJECT_ID=
GTM_ACCESS_TOKEN=
GOOGLE_TAG_MANAGER_ACCESS_TOKEN=
GTM_SERVICE_ACCOUT=
GTM_SERVICE_ACCOUNT=
GTM_SERVICE_ACCOUNT_JSON_PATH=
GOOGLE_TAG_MANAGER_SERVICE_ACCOUNT_JSON=
GTM_ACCOUNT_ID=
# Numeric GTM API container id. The public web container id stays below.
GTM_CONTAINER_ID=
GTM_WORKSPACE_ID=
GTM_WEB_ACCOUNT_ID=
GTM_WEB_CONTAINER_ID=
GTM_WEB_WORKSPACE_ID=
GTM_WEB_PUBLIC_CONTAINER_ID=GTM-5TWMJQFP
GTM_SERVER_ACCOUNT_ID=
GTM_SERVER_CONTAINER_ID=
GTM_SERVER_WORKSPACE_ID=
GTM_SERVER_PUBLIC_CONTAINER_ID=
GTM_TRIGGER_ID=
NEXT_PUBLIC_GOOGLE_GTM_ID=GTM-5TWMJQFP

# --- Meta Ads MCP ---
META_ACCESS_TOKEN=
META_APP_ID=
META_AUTO_REFRESH=false
META_BUSINESS_ID=
META_AD_ACCOUNT_ID=
META_PIXEL_ID=

# --- Microsoft Advertising / Bing Ads ---
MICROSOFT_ADS_DEVELOPER_TOKEN=
MICROSOFT_ADS_CLIENT_ID=
MICROSOFT_ADS_CLIENT_SECRET=
MICROSOFT_ADS_ACCESS_TOKEN=
MICROSOFT_ADS_REFRESH_TOKEN=
MICROSOFT_ADS_CUSTOMER_ID=
MICROSOFT_ADS_ACCOUNT_ID=
MICROSOFT_ADS_ENVIRONMENT=production
MICROSOFT_MERCHANT_CENTER_STORE_ID=

# --- Microsoft UET / Clarity ---
MICROSOFT_UET_TAG_ID=
# UET tag ApiToken (Microsoft Conversions API: tagID + token). Not MICROSOFT_ADS_ACCESS_TOKEN.
MICROSOFT_UET_CAPI_ACCESS_TOKEN=
MICROSOFT_UET_CAPI_TOKEN=
UTEKOS_MICROSOFT_UET_CAPI_TOKEN=
MICROSOFT_ADS_UET_CAPI_TOKEN=
MICROSOFT_CLARITY_PROJECT_ID=

# --- PostHog ---
POSTHOG_ORGANIZATION_ID=
POSTHOG_PROJECT_ID=
POSTHOG_PERSONAL_API_KEY=
POSTHOG_CUSTOM_API_KEY=
POSTHOG_API_HOST=https://eu.posthog.com
POSTHOG_UI_HOST=https://eu.posthog.com
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=
NEXT_PUBLIC_POSTHOG_HOST=https://portal.utekos.no
NEXT_PUBLIC_POSTHOG_UI_HOST=https://eu.posthog.com
NEXT_PUBLIC_POSTHOG_SESSION_REPLAY=1

# --- Sentry MCP ---
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
NEXT_PUBLIC_SENTRY_DSN=

# --- Vercel MCP ---
VERCEL_TOKEN=
VERCEL_PROJECT_ID=
VERCEL_TEAM_ID=
VERCEL_ORG_ID=

# --- Credential file paths (repo-relative; files live under src/api/lib/cloud-credentials/) ---
GA_SERVICE_ACCOUNT_JSON=src/api/lib/cloud-credentials/google-analytics-data-api-service-account.json
GOOGLE_APPLICATION_CREDENTIALS=src/api/lib/cloud-credentials/search-console-credentials.json
MERCHANT_CENTER_CREDENTIALS_PATH=src/api/lib/cloud-credentials/merchant-center-credentials.json

# --- Public remote MCP endpoints ---
UTEKOS_CSS_INSIGHT_MCP_URL=
